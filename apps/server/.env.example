# Copy to .env and fill in values. Loaded by your shell / process manager (Nest does not read .env automatically).

# --- Core ---
DATABASE_URL=postgresql://vigil:vigil@localhost:5432/vigil?schema=public

# HTTP listen port (optional, default 3000)
# PORT=3000

# --- Notifications (optional; set SNS_TOPIC_ARN to enable) ---
# See docs/notifications.md for behavior and local verification.

# mock = log alerts to server stdout (default; no AWS needed)
# sns  = publish via AWS SNS (requires SNS_TOPIC_ARN and IAM)
NOTIFICATION_BACKEND=mock

# Required for SNS backend; also gates notificationsReady in the client
# SNS_TOPIC_ARN=arn:aws:sns:us-west-2:123456789012:vigil-alerts

# AWS region for SNS (required when SNS_TOPIC_ARN is set)
# AWS_REGION=us-west-2

# Canonical public origin of the Vigil SPA (watch links in alert bodies)
PUBLIC_BASE_URL=http://localhost:5173
